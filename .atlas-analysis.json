  "keyFeatures": [
    "DID-based authentication and identity management",
    "Blocklet lifecycle management (install, start, stop, upgrade, remove)",
    "Nginx-based request routing with automatic configuration",
    "Role-based access control (RBAC) with team management",
    "Blue-green zero-downtime deployment",
    "GraphQL API for server and blocklet management",
    "Web dashboard for visual administration",
    "PM2-based process management for blocklets",
    "Docker support for containerized blocklets",
    "Event-driven architecture with lifecycle hooks",
    "Automatic SSL certificate management",
    "Node.js and browser SDKs for blocklet development"
  ],
